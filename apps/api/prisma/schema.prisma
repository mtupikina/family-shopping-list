generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemStatus {
  NEW
  REJECTED
  COMPLETED
}

model Family {
  id        String         @id @default(uuid())
  name      String
  createdAt DateTime       @default(now())
  members   Member[]
  invites   FamilyInvite[]
  items     ShoppingItem[]
}

model Member {
  id            String         @id @default(uuid())
  email         String         @unique
  username      String
  familyId      String
  family        Family         @relation(fields: [familyId], references: [id])
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
  itemsCreated  ShoppingItem[] @relation("ItemCreatedBy")
  itemsRejected ShoppingItem[] @relation("ItemRejectedBy")
  itemsCompleted ShoppingItem[] @relation("ItemCompletedBy")
}

model FamilyInvite {
  id         String           @id @default(uuid())
  familyId   String
  family     Family           @relation(fields: [familyId], references: [id])
  email      String
  invitedBy  String
  tokenHash  String           @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime         @default(now())
  magicLinks MagicLinkToken[]

  @@index([familyId, email])
}

model MagicLinkToken {
  id        String        @id @default(uuid())
  email     String
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())
  inviteId  String?
  invite    FamilyInvite? @relation(fields: [inviteId], references: [id])
}

model RefreshToken {
  id        String    @id @default(uuid())
  memberId  String
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model ShoppingItem {
  id            String     @id @default(uuid())
  familyId      String
  family        Family     @relation(fields: [familyId], references: [id])
  text          String
  quantity      Decimal?
  unit          String?
  category      String?
  status        ItemStatus @default(NEW)
  archived      Boolean    @default(false)
  archivedAt    DateTime?
  createdById   String
  createdBy     Member     @relation("ItemCreatedBy", fields: [createdById], references: [id])
  rejectedById  String?
  rejectedBy    Member?    @relation("ItemRejectedBy", fields: [rejectedById], references: [id])
  rejectReason  String?
  rejectedAt    DateTime?
  completedById String?
  completedBy   Member?    @relation("ItemCompletedBy", fields: [completedById], references: [id])
  price         Decimal?
  store         String?
  completedAt   DateTime?
  version       Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([familyId, archived, status])
}
